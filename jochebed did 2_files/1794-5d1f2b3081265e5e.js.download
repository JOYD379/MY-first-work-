y used GridItemFields are updated to\n# use the CPE API, they use this fragment instead. Once we have\n# removed all use of GridItemFields, we can rename this fragment.\n\nfragment GridItemFieldsCPESubset on Item {\n  createdAt\n  id\n  ... on Pen {\n    cpid\n    isNewEditorPen\n  }\n\n  access\n  token\n  private\n  streamForeignId\n  title\n  updatedAt\n  url\n  itemType\n\n  counts {\n    comments\n    loves\n    views\n  }\n\n  owner {\n    anon\n    avatar\n    url\n    id\n    pro\n    title\n    username\n    ownerType\n\n    sessionUser {\n      id\n      followsOwner\n      isBannedByOwner\n    }\n  }\n\n  sessionUser {\n    id\n    loveLevel\n    ownsItem\n  }\n\n  ... on Collection {\n    ...GridCollectionFields\n  }\n\n  ... on Pen {\n    ...GridPenFields\n  }\n\n  ... on Project {\n    ...GridProjectFields\n  }\n\n  ... on Post {\n    ...GridPostFields\n  }\n}\n\nfragment GridItemFieldsCPESubsetPen on Pen {\n  id\n  ...GridItemFieldsCPESubset\n}\n\n# everything you need to display an Item in a grid with <ContentGridItem />\nfragment GridItemFields on Item {\n  access\n  createdAt\n  id\n  ... on Pen {\n    cpid\n    isNewEditorPen\n  }\n  token\n  itemType\n  private\n  streamForeignId\n  title\n  updatedAt\n  url\n\n  counts {\n    comments\n    loves\n    views\n  }\n\n  owner {\n    anon\n    avatar80\n    baseUrl\n    id\n    ownerType\n    pro\n    title\n    username\n\n    sessionUser {\n      id\n      followsOwner\n      isBannedByOwner\n    }\n  }\n\n  sessionUser {\n    id\n    loveLevel\n    ownsItem\n  }\n\n  ... on Collection {\n    ...GridCollectionFields\n  }\n\n  ... on Pen {\n    ...GridPenFields\n  }\n\n  ... on Post {\n    ...GridPostFields\n  }\n\n  ... on Project {\n    ...GridProjectFields\n  }\n}\n\n# Fields on Collection\nfragment GridCollectionFields on Collection {\n  id\n  counts {\n    items\n  }\n\n  description {\n    processed {\n      body\n    }\n  }\n\n  urls {\n    full\n  }\n\n  ...ItemPreviewImageFields\n}\n\n# Fields on Pen\nfragment GridPenFields on Pen {\n  id\n  urls {\n    details\n    full\n    template\n  }\n  template\n  previews {\n    iframeUrl\n    shotUrlTemplate\n    showScreenshot\n  }\n}\n\n# Fields on Post\nfragment GridPostFields on Post {\n  id\n  previews {\n    summary {\n      processed {\n        body\n      }\n    }\n  }\n}\n\n# Fields on Project\nfragment GridProjectFields on Project {\n  id\n  # TODO: template for Project in cpengine\n  urls {\n    details\n    full\n  }\n  previews {\n    shotUrlTemplate\n  }\n}\n\n# Fields on Popular Pens - included in Following feed, Follow suggestions\nfragment UserPopularPensFields on Pen {\n  id\n  url\n  previews {\n    id\n    shotUrlTemplate\n  }\n  ...ItemPreviewImageFields\n}\n',name:"GraphQL request",locationOffset:{line:1,column:1}};var a={};t.definitions=t.definitions.concat(i(49183).definitions.filter(function(e){if("FragmentDefinition"!==e.kind)return!0;var n=e.name.value;return!a[n]&&(a[n]=!0,!0)}));var d={};function l(e,n){for(var i=0;i<e.definitions.length;i++){var t=e.definitions[i];if(t.name&&t.name.value==n)return t}}function o(e,n){var i={kind:e.kind,definitions:[l(e,n)]};e.hasOwnProperty("loc")&&(i.loc=e.loc);var t=d[n]||new Set,a=new Set,o=new Set;for(t.forEach(function(e){o.add(e)});o.size>0;){var s=o;o=new Set,s.forEach(function(e){a.has(e)||(a.add(e),(d[e]||new Set).forEach(function(e){o.add(e)}))})}return a.forEach(function(n){var t=l(e,n);t&&i.definitions.push(t)}),i}t.definitions.forEach(function(e){if(e.name){var n=new Set;!function e(n,i){if("FragmentSpread"===n.kind)i.add(n.name.value);else if("VariableDefinition"===n.kind){var t=n.type;"NamedType"===t.kind&&i.add(t.name.value)}n.selectionSet&&n.selectionSet.selections.forEach(function(n){e(n,i)}),n.variableDefinitions&&n.variableDefinitions.forEach(function(n){e(n,i)}),n.definitions&&n.definitions.forEach(function(n){e(n,i)})}(e,n),d[e.name.value]=n}}),e.exports=t,e.exports.GridItemFieldsCPESubset=o(t,"GridItemFieldsCPESubset"),e.exp